# Copy this file to secrets.toml and fill in real values.
# secrets.toml is gitignored — never commit real credentials.
# These power Streamlit's st.login() against WCA's OAuth provider.

[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
cookie_secret = "<random-long-string>"
expose_tokens = ["access"]

[auth.wca]
client_id = "<your-wca-oauth-app-id>"
client_secret = "<your-wca-oauth-secret>"
server_metadata_url = "https://www.worldcubeassociation.org/.well-known/openid-configuration"
# manage_competitions scope is required to load the private WCIF of unpublished competitions
client_kwargs = { "scope" = "openid profile public email manage_competitions", "prompt" = "consent" }
